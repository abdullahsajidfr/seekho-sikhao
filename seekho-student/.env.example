# Firebase (Realtime Database + Storage) — student app.
#
# Leave these BLANK to run the app in offline demo mode: a static demo session
# renders every screen with representative content and all reads/writes no-op.
#
# Provide them (same project as the wizard web surface) to make the app live —
# the WoZ wizard then drives this device in real time. No Firebase Auth is used;
# the RTDB + Storage security rules are open for the testing period (see spec).
#
# In Expo, any variable prefixed EXPO_PUBLIC_ is inlined into the client bundle.
# Copy this file to `.env` and fill in the values from the Firebase console.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: Google Sheets logging endpoint used by admin.logEvent (fire-and-forget).
# EXPO_PUBLIC_SHEETS_ENDPOINT=
